{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "api/index.py"
    },
    {
      "src": "/api/test",
      "dest": "api/index.py"
    },
    {
      "src": "/api/index.py",
      "dest": "api/index.py"
    },
    {
      "src": "/api/create-playlist.js",
      "dest": "api/create-playlist.js"
    },
    {
      "src": "/api/exchange-token.js",
      "dest": "api/exchange-token.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
